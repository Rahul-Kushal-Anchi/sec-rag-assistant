# --- Database -----------------------------------------------------------------
# Async SQLAlchemy URL. Use asyncpg driver for Postgres.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sec_rag

# --- LLM providers ------------------------------------------------------------
# Anthropic Claude (default LLM). Required.
ANTHROPIC_API_KEY=sk-ant-replace-me
# OpenAI (embeddings + fallback LLM). Required.
OPENAI_API_KEY=sk-replace-me

# --- Observability ------------------------------------------------------------
# Optional LangSmith API key for tracing. Leave blank to disable.
LANGSMITH_API_KEY=
# Project name reported to LangSmith.
LANGSMITH_PROJECT=sec-rag-assistant
# Toggle tracing on/off.
LANGSMITH_TRACING=false

# --- Models -------------------------------------------------------------------
# OpenAI embedding model used to index chunks.
EMBEDDING_MODEL=text-embedding-3-small
# Cross-encoder reranker for two-stage retrieval.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Application --------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
